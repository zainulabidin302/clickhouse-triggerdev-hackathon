# Copy to .env and fill in. Never commit .env.

# --- ClickHouse Cloud (OLAP: HN corpus + embeddings) ---
CLICKHOUSE_URL=https://<service-id>.<region>.<provider>.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# No Postgres — session state lives in ClickHouse too.
# See docs/decisions/03-oltp-olap-split.md

# --- LLM ---
ANTHROPIC_API_KEY=

# No embedding credential needed. The corpus uses all-MiniLM-L6-v2 (384 dims),
# a local model — we run it in-task via Transformers.js.
# See docs/decisions/04-embedding-model.md
