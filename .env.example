# Copy to .env and fill in. Never commit .env.

# --- ClickHouse Cloud (OLAP: HN corpus + embeddings) ---
CLICKHOUSE_URL=https://<service-id>.<region>.<provider>.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# No Postgres — session state lives in ClickHouse too.
# See docs/decisions/03-oltp-olap-split.md

# --- LLM ---
# Model must match the HN vector dataset's embedding model/dims for new posts.
# See docs/decisions/01-dataset-hacker-news.md — verify before ingesting.
ANTHROPIC_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMS=
